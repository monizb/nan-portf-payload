{
  "name": "nanditha-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx src/scripts/seed.ts",
    "generate:types": "payload generate:types",
    "deploy": "npm run deploy:database && npm run deploy:app",
    "deploy:app": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && npx wrangler d1 execute D1 --command 'PRAGMA optimize' --remote"
  },
  "dependencies": {
    "@payloadcms/db-d1-sqlite": "^3.80.0",
    "@payloadcms/db-sqlite": "^3.80.0",
    "@payloadcms/next": "^3.80.0",
    "@payloadcms/richtext-lexical": "^3.80.0",
    "@payloadcms/storage-r2": "^3.80.0",
    "@payloadcms/storage-s3": "^3.80.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "graphql": "^16.13.1",
    "next": "16.2.1",
    "payload": "^3.80.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.183.1",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  }
}
